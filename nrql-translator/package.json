{
  "name": "@bhdynatrace/nrql-translator",
  "version": "1.0.0",
  "description": "NRQL to DQL translation library for New Relic to Dynatrace migration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/core",
    "dist/index.js",
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "dist/index.js.map"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "build:cli": "tsc -p tsconfig.cli.json",
    "build:all": "npm run build && npm run build:cli",
    "cli": "npm run build:cli && node dist-cli/cli/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist dist-cli",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bhdynatrace/nrql-translator.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "keywords": [
    "newrelic",
    "dynatrace",
    "nrql",
    "dql",
    "migration",
    "translator",
    "query-conversion"
  ],
  "author": "Dynabridge Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bhdynatrace/nrql-translator/issues"
  },
  "homepage": "https://github.com/bhdynatrace/nrql-translator#readme",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "commander": "^12.1.0",
    "eslint": "^8.57.0",
    "exceljs": "^4.4.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
